# Copy this file to .env and fill in your values
# cp .env.example .env

# ── LLM Provider ───────────────────────────────────────────────────────────────
# "openai"  → use OpenAI API directly (default)
# "azure"   → use Azure OpenAI Service via Azure AI Foundry
LLM_PROVIDER=openai

# ── OpenAI (used when LLM_PROVIDER=openai) ────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Azure OpenAI (used when LLM_PROVIDER=azure) ───────────────────────────────
# Found in Azure Portal → your Azure OpenAI resource → Keys and Endpoint
AZURE_OPENAI_API_KEY=
# Resource endpoint, e.g. https://my-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=
# Deployment name you created in Azure AI Foundry (Models + Deployments)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# API version (leave as default unless Azure requires a newer one)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Shared LLM Settings ────────────────────────────────────────────────────────
# Model name (only used for LLM_PROVIDER=openai)
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Controls which embedding backend and model to use.
# Changing EMBEDDING_MODEL or EMBEDDING_PROVIDER after building an index
# requires a full re-ingest — different models produce incompatible vector spaces.
#
# EMBEDDING_PROVIDER options:
#   huggingface  — sentence-transformers, fully local, no server needed (default)
#   ollama       — Ollama daemon (run `ollama serve` then `ollama pull <model>`)

EMBEDDING_PROVIDER=huggingface

# ── HuggingFace free model catalogue ──────────────────────────────────────────
# Paste one of the model names below as EMBEDDING_MODEL.
# All are free, run locally on CPU, and auto-downloaded on first use.
#
# Model                          Dim   Max tokens  Size    Notes
# ─────────────────────────────────────────────────────────────────────────────
# BAAI/bge-small-en-v1.5         384   512         ~130MB  Best speed/quality ratio (DEFAULT)
# BAAI/bge-base-en-v1.5          768   512         ~430MB  Balanced — good step-up from small
# BAAI/bge-large-en-v1.5         1024  512         ~1.3GB  Near-API quality, needs more RAM
# nomic-ai/nomic-embed-text-v1   768   8192        ~550MB  Best for long documents (8k tok ctx)
# all-mpnet-base-v2              768   514         ~420MB  Strong general-purpose baseline
# all-MiniLM-L6-v2               384   256         ~90MB   Original default — fast but 256-tok limit
#
# Recommendation for most projects: BAAI/bge-small-en-v1.5 (default)
# Recommendation for long chunks / big docs: nomic-ai/nomic-embed-text-v1

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Ollama embedding models (only used when EMBEDDING_PROVIDER=ollama) ─────────
# Pull a model first: `ollama pull <model-name>`
#
# Model                    Dim    Max tokens  Notes
# ────────────────────────────────────────────────────────────────────
# nomic-embed-text         768    8192        Best all-around, long context
# mxbai-embed-large        1024   512         High quality, similar to bge-large
# all-minilm               384    512         Lightweight, fast
#
# Example — switch to Ollama with nomic-embed-text:
#   EMBEDDING_PROVIDER=ollama
#   EMBEDDING_MODEL=nomic-embed-text

# ── Vector Store ────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=faiss_index

# ── Chunking ────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
